# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role key (NOT the anon key) — has full DB access, keep secret
# Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=replace-with-real-service-role-key

# ── JWT (your own tokens — separate from Supabase auth) ───────────────────────
JWT_SECRET=supersecretjwtkey_change_in_production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create app: https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:8080
# Callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── Razorpay (test mode) ──────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys → Test Mode
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:8080
