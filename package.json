{
  "name": "todo-app-root",
  "version": "1.0.0",
  "description": "Root package for Todo App",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "npx -y serve frontend -l 8080",
    "dev": "npx -y concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test:smoke": "./smoke-test.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
